  config            Json      @default("{}")
  autoEventsEnabled Boolean   @default(true)       @map("auto_events_enabled")
  connectedAt       DateTime?                      @map("connected_at")
  createdAt         DateTime  @default(now())      @map("created_at")
  updatedAt         DateTime  @updatedAt           @map("updated_at")

  pixel MetaPixel @relation(fields: [pixelId], references: [id], onDelete: Cascade)

  @@unique([pixelId, partnerName])
  @@index([pixelId])
  @@map("meta_partner_integrations")
}

model MetaSignalsGateway {
